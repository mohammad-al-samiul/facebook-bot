# Copy to .env and fill in your values (never commit .env)

# Ollama — local LLM brain (default desktop port 11434)
OLLAMA_HOST=127.0.0.1:11434
OLLAMA_BASE_URL=http://127.0.0.1:11434
OLLAMA_MODEL=llama3.1:8b

# Optional: Gemini fallback when Ollama is offline (comments / captions)
GEMINI_API_KEY=

# Min friends or followers to send friend requests (default 2000)
MIN_AUDIENCE_FRIEND_REQUEST=2000

# Human typing behaviour (share captions, comments)
HUMAN_TYPO_RATE=0.045
HUMAN_RETHINK_RATE=0.10
HUMAN_WORD_PAUSE_MIN=0.14
COMMENT_SETTLE_SEC=5
COMMENT_SETTLE_MAX_SEC=7

# Daily quotas are set via CLI on run_agent_brain.py:
#   --daily-friend-min 3 --daily-friend-max 4
#   --daily-post-min 3 --daily-post-max 5
