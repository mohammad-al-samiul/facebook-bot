# MongoDB Atlas (do NOT commit to git — .gitignore covers .env)
MONGO_URI=mongodb+srv://dbFbBot:dbFbBot@cluster0.5ylvmb9.mongodb.net/fb-bot?appName=Cluster0
MONGO_DB=fb-bot

INITIAL_STAGGER_MAX_SEC=2
ACTION_GAP_MIN_SEC=10
ACTION_GAP_MAX_SEC=30
WARMUP_GAP_MIN_SEC=10
WARMUP_GAP_MAX_SEC=30

# Gemini (Google Generative Language) API key for AI-written comments.
# Used by playwright_automation/ai_comment.py.
GEMINI_API_KEY=AIzaSyCSZeSnJs6RUqUtQwu6WoXqoJ6QIRYk_A4

# Ollama — local brain for reactions + comments (fleet_worker smart engagement).
# Match your ``ollama serve`` terminal (Ollama CLI uses OLLAMA_HOST host:port)
# Example: export OLLAMA_HOST="127.0.0.1:18000" && ollama serve
OLLAMA_HOST=127.0.0.1:18000
OLLAMA_BASE_URL=http://127.0.0.1:18000
OLLAMA_MODEL=llama3.1:8b

# Seconds to wait on screen after posting a comment before tapping Back (default 5).
COMMENT_SETTLE_SEC=5
COMMENT_SETTLE_MAX_SEC=7
HUMAN_TYPO_RATE=0.045
HUMAN_RETHINK_RATE=0.10
HUMAN_WORD_PAUSE_MIN=0.14
HUMAN_WORD_PAUSE_MAX=0.55

# Profile stalk (friend suggestions → open profile): browse time + selective engage
# PROFILE_STALK_MIN_SEC=28
# PROFILE_STALK_MAX_SEC=45
# PROFILE_STALK_ENGAGE=2
# PROFILE_STALK_MIN_APPEAL=42